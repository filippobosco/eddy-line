---
/**
 * Hero (§7.2) — livello attività + firma brand permanente.
 * Rende lo stato d'ingresso server-side (SEO/no-JS) con la copy ESATTA del
 * brief. Per lo swap senza reload (§5.3), incorpora i dati di TUTTI gli stati
 * in uno <script type="application/json">: il controller riscrive il contenuto.
 *
 * Sequenza orchestrata leggera al load (.hero-stagger), reduced-motion ok.
 */
import config from '../config';
import { heroByActivity } from '../data/content';
import type { Activity } from '../data/content';
import CurrentLine from './CurrentLine.astro';

interface Props {
  activity: Activity | 'neutral';
}
const { activity } = Astro.props;
const hero = heroByActivity[activity];

const imageByState: Record<Activity | 'neutral', string> = {
  neutral: config.assets.heroNeutralImage,
  rafting: config.assets.heroRaftingImage,
  canyoning: config.assets.heroCanyoningImage,
};
const heroImage = imageByState[activity];

// Payload completo per lo swap client-side (copy + immagini dei 3 stati).
const heroPayload = {
  states: heroByActivity,
  images: imageByState,
};
---

<section class="hero" data-hero data-activity={activity} aria-labelledby="hero-title">
  <div class="hero__bg" aria-hidden="true">
    <img
      src={heroImage}
      alt=""
      class="hero__img"
      fetchpriority="high"
      decoding="async"
      data-hero-img
    />
    <div class="hero__veil"></div>
    <svg class="hero__current" viewBox="0 0 600 200" aria-hidden="true" preserveAspectRatio="none">
      <path
        d="M-20,150 C120,60 260,180 400,90 C500,30 560,70 620,40"
        fill="none"
        stroke="var(--sesia-bright)"
        stroke-width="2.5"
        stroke-linecap="round"
        opacity="0.55"></path>
    </svg>
  </div>

  <div class="container hero__inner hero-stagger">
    <p class="eyebrow hero__eyebrow" style="--i:0" data-hero-eyebrow>{hero.eyebrow}</p>

    <h1 class="hero__title" id="hero-title" style="--i:1" data-hero-h1>{hero.h1}</h1>

    <div style="--i:2">
      <CurrentLine variant="underline" class="hero__underline" />
    </div>

    <p class="hero__sub" style="--i:3" data-hero-sub>{hero.sub}</p>

    <p
      class="tag-mono hero__tag"
      style="--i:4"
      data-hero-tag
      hidden={!hero.tagMono}
    >
      {hero.tagMono}
    </p>

    <div class="hero__ctas" style="--i:5">
      <a class="btn btn-primary" href={hero.ctaPrimary.target} data-hero-cta-primary>
        {hero.ctaPrimary.label}
      </a>
      <a
        class="btn btn-ghost-light"
        href={hero.ctaSecondary?.target ?? '#prenota'}
        data-hero-cta-secondary
        hidden={!hero.ctaSecondary}
      >
        {hero.ctaSecondary?.label}
      </a>
    </div>
  </div>

  <!-- Payload per lo swap client-side (§5.3) -->
  <script is:inline type="application/json" data-hero-payload set:html={JSON.stringify(heroPayload)} />
</section>

<style>
  .hero {
    position: relative;
    isolation: isolate;
    min-height: clamp(34rem, 82vh, 46rem);
    display: flex;
    align-items: flex-end;
    padding-block: clamp(2.5rem, 8vh, 5rem);
    overflow: hidden;
    background: var(--granite);
    color: var(--text-on-dark);
  }

  .hero__bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }
  .hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 35%;
    transition: opacity var(--dur) var(--ease-out);
  }
  .hero[data-swapping='true'] .hero__img {
    opacity: 0.55;
  }
  .hero__veil {
    position: absolute;
    inset: 0;
    background:
      /* velo dal basso: protegge titolo + CTA */
      linear-gradient(
        180deg,
        rgba(27, 36, 38, 0.5) 0%,
        rgba(27, 36, 38, 0.42) 38%,
        rgba(27, 36, 38, 0.96) 100%
      ),
      /* alone brand in alto a destra */
      radial-gradient(120% 80% at 80% 0%, rgba(14, 90, 82, 0.5) 0%, transparent 60%),
      /* tinta brand uniforme per garantire contrasto AA del testo ovunque */
      color-mix(in srgb, var(--granite) 22%, transparent);
  }
  /* Su schermi larghi il contenuto è centrato a sinistra: scuriamo quel lato */
  @media (min-width: 720px) {
    .hero__veil {
      background:
        linear-gradient(
          90deg,
          rgba(27, 36, 38, 0.78) 0%,
          rgba(27, 36, 38, 0.5) 42%,
          rgba(27, 36, 38, 0.2) 100%
        ),
        linear-gradient(180deg, rgba(27, 36, 38, 0.2) 0%, rgba(27, 36, 38, 0.72) 100%),
        radial-gradient(120% 80% at 85% 0%, rgba(14, 90, 82, 0.4) 0%, transparent 55%);
    }
  }
  .hero__current {
    position: absolute;
    top: 8%;
    right: -4%;
    width: min(60%, 28rem);
    height: auto;
    z-index: 1;
    pointer-events: none;
  }

  .hero__inner {
    position: relative;
    z-index: 2;
    max-width: 46rem;
  }
  .hero__eyebrow {
    color: var(--sesia-bright);
  }
  .hero__title {
    color: var(--foam);
    font-size: var(--step-5);
    max-width: 18ch;
    margin-top: 0.6rem;
  }
  .hero__underline {
    color: var(--sesia-bright);
  }
  .hero__sub {
    margin-top: 1.25rem;
    max-width: 48ch;
    font-size: var(--step-1);
    color: color-mix(in srgb, var(--foam) 90%, transparent);
    line-height: 1.5;
  }
  .hero__tag {
    margin-top: 1.1rem;
    color: var(--sesia-bright);
    font-size: var(--step-0);
    letter-spacing: 0.02em;
  }
  .hero__tag[hidden] {
    display: none;
  }
  .hero__ctas {
    margin-top: 1.75rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }
  .hero__ctas [hidden] {
    display: none;
  }

  @media (min-width: 720px) {
    .hero {
      align-items: center;
    }
  }
</style>
