---
/**
 * FAQ (§7.10) — accordion accessibile.
 * Usa <details>/<summary> nativi: tastiera + screen reader gratis, funziona
 * senza JS. Animazione leggera dell'icona (reduced-motion ok). Le FAQ reali
 * (§8.3) sono in content.ts; per ora tutte 'permanente'.
 */
import { faqs } from '../data/content';
import CurrentLine from './CurrentLine.astro';
---

<section class="faq section" id="faq" aria-labelledby="faq-title">
  <div class="container container-narrow">
    <div class="faq__head reveal">
      <p class="eyebrow">DOMANDE FREQUENTI</p>
      <h2 class="faq__title" id="faq-title">Le risposte che cerchi prima di prenotare</h2>
      <CurrentLine variant="underline" animate={true} class="faq__underline" />
    </div>

    <div class="faq__list">
      {
        faqs.map((f) => (
          <details class="faq__item reveal" name="faq">
            <summary class="faq__q">
              <span>{f.q}</span>
              <span class="faq__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="22" height="22">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.2"
                    stroke-linecap="round"
                    d="M12 5v14M5 12h14"
                  />
                </svg>
              </span>
            </summary>
            <div class="faq__a">
              <p>{f.a}</p>
            </div>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq__head {
    text-align: center;
    margin-bottom: clamp(1.5rem, 4vw, 2.25rem);
  }
  .faq__title {
    font-size: var(--step-3);
    margin-top: 0.5rem;
    max-width: 20ch;
    margin-inline: auto;
  }
  .faq__underline {
    margin-inline: auto;
  }

  .faq__list {
    display: grid;
    gap: 0.75rem;
  }
  .faq__item {
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--dur-fast) var(--ease-out);
  }
  .faq__item[open] {
    border-color: var(--sesia-bright);
  }

  .faq__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.1rem 1.3rem;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--step-1);
    color: var(--text);
  }
  /* nasconde il marker di default (triangolo) */
  .faq__q::-webkit-details-marker {
    display: none;
  }

  .faq__icon {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--sesia-bright-15);
    color: var(--sesia-deep);
    transition: transform var(--dur) var(--ease-out), background-color var(--dur-fast) var(--ease-out);
  }
  .faq__item[open] .faq__icon {
    transform: rotate(45deg);
    background: var(--sesia-deep);
    color: var(--foam);
  }

  .faq__a {
    padding: 0 1.3rem 1.3rem;
    color: var(--text-mute);
    font-size: var(--step-0);
    line-height: 1.6;
  }
  /* rivelazione morbida del contenuto */
  .faq__item[open] .faq__a {
    animation: faq-reveal var(--dur) var(--ease-out);
  }
  @keyframes faq-reveal {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
    to {
      opacity: 1;
      transform: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .faq__item[open] .faq__a {
      animation: none;
    }
    .faq__icon {
      transition: none;
    }
  }
</style>
