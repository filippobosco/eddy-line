---
/**
 * Footer (§7.13) — permanente. È il "terzo step" di contatto.
 * Telefono (click-to-call), WhatsApp (wa.me), email, indirizzo base, social
 * (FB/IG), link Privacy & Cookie, P.IVA. Tracking whatsapp_click / call_click.
 */
import config from '../config';
import { contacts } from '../data/content';
import CurrentLine from './CurrentLine.astro';

const year = 2026; // anno fisso (no Date.now in build statico)
const { logoUrl } = config.assets;
---

<footer class="footer" aria-labelledby="footer-title">
  <CurrentLine variant="separator" class="footer__current" />

  <div class="container footer__inner">
    <div class="footer__brand">
      <img src={logoUrl} alt="Eddyline" width="150" height="44" class="footer__logo" />
      <p class="footer__tagline">
        Centro Sport Fluviali Valsesia — sul fiume Sesia, a Campertogno (VC), dal 2001.
      </p>
      <div class="footer__social" aria-label="Social">
        <a href={contacts.facebook} target="_blank" rel="noopener" aria-label="Facebook">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path
              fill="currentColor"
              d="M14 8.5h2.5V5.3h-2.6c-2.4 0-3.9 1.5-3.9 4v1.9H7.5v3.2h2.5V22h3.3v-7.6h2.5l.4-3.2h-2.9V9.5c0-.7.3-1 1.2-1z"
            ></path>
          </svg>
        </a>
        <a href={contacts.instagram} target="_blank" rel="noopener" aria-label="Instagram">
          <svg viewBox="0 0 24 24" width="22" height="22" aria-hidden="true">
            <path
              fill="none"
              stroke="currentColor"
              stroke-width="1.8"
              d="M7 3.5h10A3.5 3.5 0 0 1 20.5 7v10a3.5 3.5 0 0 1-3.5 3.5H7A3.5 3.5 0 0 1 3.5 17V7A3.5 3.5 0 0 1 7 3.5z"
            ></path>
            <circle cx="12" cy="12" r="3.4" fill="none" stroke="currentColor" stroke-width="1.8"
            ></circle>
            <circle cx="17.2" cy="6.8" r="1.1" fill="currentColor"></circle>
          </svg>
        </a>
      </div>
    </div>

    <div class="footer__col">
      <h2 class="footer__h" id="footer-title">Contatti</h2>
      <ul class="footer__list">
        <li>
          <a class="footer__contact" href={contacts.phoneHref} data-track="call_click">
            <span class="footer__contact-label">Telefono (tutto l’anno)</span>
            <span class="footer__contact-value">{contacts.phoneDisplay}</span>
          </a>
        </li>
        <li>
          <a
            class="footer__contact"
            href={contacts.whatsapp}
            target="_blank"
            rel="noopener"
            data-track="whatsapp_click"
          >
            <span class="footer__contact-label">WhatsApp</span>
            <span class="footer__contact-value">Scrivici un messaggio</span>
          </a>
        </li>
        <li>
          <a class="footer__contact" href={`mailto:${contacts.email}`}>
            <span class="footer__contact-label">Email</span>
            <span class="footer__contact-value">{contacts.email}</span>
          </a>
        </li>
      </ul>
    </div>

    <div class="footer__col">
      <h2 class="footer__h">La base</h2>
      <address class="footer__address">
        {contacts.base}
      </address>
      <a class="btn btn-primary footer__cta" href="#prenota">Prenota la tua data</a>
    </div>
  </div>

  <div class="container footer__bottom">
    <p class="footer__legal">
      © {year} {contacts.legalName} · P.IVA {contacts.vat}
    </p>
    <a class="footer__privacy" href={contacts.privacyUrl} target="_blank" rel="noopener">
      Privacy &amp; Cookie
    </a>
  </div>
</footer>

<style>
  .footer {
    background: var(--granite);
    color: var(--foam);
  }
  .footer__current {
    color: var(--sesia-bright);
    opacity: 0.5;
    height: 36px;
  }

  .footer__inner {
    display: grid;
    gap: 2.25rem;
    padding-block: clamp(2.5rem, 6vw, 4rem) 2rem;
  }

  .footer__logo {
    height: 40px;
    width: auto;
    /* il logo PNG ha sfondo chiaro: lo schiariamo su fondo scuro */
    background: var(--foam);
    padding: 0.4rem 0.6rem;
    border-radius: var(--radius-sm);
  }
  .footer__tagline {
    margin-top: 1rem;
    color: color-mix(in srgb, var(--foam) 72%, transparent);
    max-width: 38ch;
    font-size: var(--step-0);
  }
  .footer__social {
    margin-top: 1.25rem;
    display: flex;
    gap: 0.6rem;
  }
  .footer__social a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    color: var(--foam);
    background: rgba(242, 246, 244, 0.08);
    transition:
      background-color var(--dur-fast) var(--ease-out),
      transform var(--dur-fast) var(--ease-out);
  }
  .footer__social a:hover {
    background: var(--sesia-bright);
    color: var(--granite);
    transform: translateY(-2px);
  }

  .footer__h {
    font-size: var(--step-1);
    color: var(--foam);
    margin-bottom: 1rem;
  }
  .footer__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.9rem;
  }
  .footer__contact {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    text-decoration: none;
    color: var(--foam);
  }
  .footer__contact-label {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sesia-bright);
  }
  .footer__contact-value {
    font-weight: 600;
    transition: color var(--dur-fast) var(--ease-out);
  }
  .footer__contact:hover .footer__contact-value {
    color: var(--sesia-bright);
  }

  .footer__address {
    font-style: normal;
    color: color-mix(in srgb, var(--foam) 82%, transparent);
    line-height: 1.6;
  }
  .footer__cta {
    margin-top: 1.25rem;
  }

  .footer__bottom {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-block: 1.5rem;
    border-top: 1px solid rgba(242, 246, 244, 0.12);
    font-size: var(--step--1);
    color: color-mix(in srgb, var(--foam) 60%, transparent);
  }
  .footer__privacy {
    color: color-mix(in srgb, var(--foam) 75%, transparent);
  }
  .footer__privacy:hover {
    color: var(--sesia-bright);
  }

  @media (min-width: 720px) {
    .footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3rem;
      align-items: start;
    }
    .footer__bottom {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
