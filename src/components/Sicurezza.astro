---
/**
 * Sicurezza & guide (§7.8) — permanente.
 * Blocco fiducia che gestisce l'obiezione "è pericoloso?". Fondo scuro
 * (granite) per dare peso/serietà, con la linea di corrente come accento.
 * Loghi enti: slot pronti in /public (CONI, FICK, FIRAFT, FICT) — finché non
 * arrivano i file, mostriamo i nomi come badge mono.
 */
import { sicurezza } from '../data/content';
import CurrentLine from './CurrentLine.astro';
---

<section class="sic section" id="sicurezza" aria-labelledby="sic-title">
  <div class="container">
    <div class="sic__grid">
      <div class="sic__intro reveal">
        <p class="eyebrow sic__eyebrow">È PERICOLOSO? NO, È METODO</p>
        <h2 class="sic__title" id="sic-title">{sicurezza.title}</h2>
        <CurrentLine variant="underline" animate={true} class="sic__underline" />
        <p class="sic__lead">{sicurezza.intro}</p>
      </div>

      <ul class="sic__points">
        {
          sicurezza.points.map((p) => (
            <li class="sic__point reveal">
              <span class="sic__check" aria-hidden="true">
                <svg viewBox="0 0 24 24" width="20" height="20">
                  <path
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.4"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </span>
              <span>{p}</span>
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Loghi enti (slot /public). Placeholder: nomi come badge. -->
    <div class="sic__enti reveal" aria-label="Enti e federazioni">
      <span class="sic__enti-label">Riconoscimenti & federazioni</span>
      <ul class="sic__enti-list">
        {
          sicurezza.enti.map((ente) => (
            <li class="sic__ente tag-mono" data-logo-slot={ente}>
              {ente}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>

<style>
  .sic {
    background: var(--granite);
    color: var(--foam);
  }
  .sic__grid {
    display: grid;
    gap: 2rem;
  }
  .sic__eyebrow {
    color: var(--sesia-bright);
  }
  .sic__title {
    color: var(--foam);
    font-size: var(--step-3);
    margin-top: 0.5rem;
  }
  .sic__lead {
    margin-top: 1rem;
    font-size: var(--step-1);
    color: color-mix(in srgb, var(--foam) 86%, transparent);
    max-width: 44ch;
  }

  .sic__points {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
  }
  .sic__point {
    display: flex;
    gap: 0.9rem;
    align-items: flex-start;
    background: rgba(242, 246, 244, 0.05);
    border: 1px solid rgba(242, 246, 244, 0.1);
    border-radius: var(--radius-md);
    padding: 1.1rem 1.2rem;
    color: color-mix(in srgb, var(--foam) 92%, transparent);
  }
  .sic__check {
    flex: 0 0 auto;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: var(--sesia-bright);
    color: var(--granite);
  }

  .sic__enti {
    margin-top: 2.5rem;
    padding-top: 1.75rem;
    border-top: 1px solid rgba(242, 246, 244, 0.12);
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }
  .sic__enti-label {
    font-family: var(--font-mono);
    font-size: var(--step--1);
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--foam) 60%, transparent);
  }
  .sic__enti-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
  }
  .sic__ente {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1rem;
    border: 1px solid rgba(242, 246, 244, 0.25);
    border-radius: var(--radius-sm);
    color: var(--foam);
    letter-spacing: 0.06em;
  }

  @media (min-width: 860px) {
    .sic__grid {
      grid-template-columns: 1fr 1fr;
      gap: 3.5rem;
      align-items: center;
    }
    .sic__enti {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }
</style>
