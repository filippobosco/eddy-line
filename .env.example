# Eddyline — variabili d'ambiente (§11 del brief)
# Copia in `.env` e riempi i valori. Le PUBLIC_* sono esposte al client.
#
# IMPORTANTE — DEPLOY VERCEL:
# Il file `.env` NON viene deployato (è gitignorato). Le stesse variabili vanno
# aggiunte anche su Vercel: Settings → Environment Variables (Production +
# Preview + Development), poi RE-DEPLOY perché abbiano effetto.
# `N8N_WEBHOOK_URL` è l'unica senza PUBLIC_ → resta solo server-side.

# --- Sito --- (per ora dominio Vercel; al go-live: prenota.eddyline.it)
PUBLIC_SUBDOMAIN="eddy-line.vercel.app"
PUBLIC_SITE_URL="https://eddy-line.vercel.app"

# --- Integrazioni ---
# Calendly — due eventi (§9.1)
PUBLIC_CALENDLY_RAFTING_URL="https://calendly.com/eddyline-info/rafting"
PUBLIC_CALENDLY_CANYONING_URL="https://calendly.com/eddyline-info/canyoning-sorba"

# Endpoint form "Richiedi informazioni" — §9.2 (server-side, NON public).
# Web App Google Apps Script del foglio "Eddyline - Contatti" (scrive nel
# foglio "Informazioni" + invia email di avviso). Vedi docs/apps-script-lead.gs
N8N_WEBHOOK_URL=""

# Google Tag Manager — §9.3 (container della landing)
PUBLIC_GTM_CONTAINER_ID="GTM-55ZJ7TMT"

# --- Asset (placeholder finché non arrivano i definitivi) ---
PUBLIC_LOGO_URL="https://eddyline.it/wp-content/uploads/2014/04/logo.png"
PUBLIC_HERO_NEUTRAL="/images/hero-neutral.jpg"
PUBLIC_HERO_RAFTING="/images/hero-rafting.jpg"
PUBLIC_HERO_CANYONING="/images/hero-canyoning.jpg"
